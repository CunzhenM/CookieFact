{
  "name": "CookieFactory",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "PlacementShared": {
        "$className": "Folder",
        "PlacementConfig": { "$path": "src/placement/shared/PlacementConfig.luau" },
        "GridUtil": { "$path": "src/placement/shared/GridUtil.luau" },
        "BuildAnimation": { "$path": "src/placement/shared/BuildAnimation.luau" }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      },
      "PlacementSystem": {
        "$path": "src/placement/server"
      },
      "PlacementOverrides": {
        "$path": "src/placement/PlacementOverrides.server.luau"
      },
      "DropperMachine": {
        "$path": "src/placement/DropperMachine.server.luau"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        },
        "PlacementClient": {
          "$path": "src/placement/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}